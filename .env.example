# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ai_creative_control?schema=public"

# Auth
# Generate locally with: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
NEXTAUTH_SECRET="replace-with-a-secure-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# Queue / cache (placeholder for generation jobs)
REDIS_URL="redis://localhost:6379"

# Storage / providers (configure when integrations are implemented)
S3_ENDPOINT=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_BUCKET=""

# Forgot-password development helper.
# Leave false in shared and production environments.
AUTH_EXPOSE_RESET_TOKEN="false"
